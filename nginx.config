# ==============================================================
# Nginx Site-Konfiguration – ScootNow
# Reverse Proxy mit HTTPS via Let's Encrypt (Certbot)
# Autor: Cristian Quarta | DBWE.TA1A.PA | 2026
# Pfad: /etc/nginx/sites-available/scootnow
# ==============================================================

# --- HTTPS Server (Port 443) ---
server {
    # Domain der Applikation
    server_name lab47.ifalabs.org;

    # Alle eingehenden Anfragen werden an Gunicorn weitergeleitet,
    # der die Flask-Applikation auf Port 8000 intern betreibt.
    location / {
        proxy_pass http://127.0.0.1:8000;

        # Originalen Hostnamen an Flask weitergeben,
        # damit URL-Generierung korrekt funktioniert.
        proxy_set_header Host $host;

        # Echte IP-Adresse des Clients an Flask weiterleiten,
        # anstatt der internen Nginx-IP.
        proxy_set_header X-Real-IP $remote_addr;

        # Liste aller durchlaufenen Proxies mitgeben.
        # Wichtig für Logging und Sicherheitsanalysen.
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # --- TLS/SSL Konfiguration (automatisch verwaltet von Certbot) ---
    # Certbot hat diese Zeilen automatisch beim Ausstellen des
    # Let's Encrypt Zertifikats eingefügt und erneuert sie automatisch.

    # Aktiviert HTTPS auf Port 443
    listen 443 ssl; # managed by Certbot

    # Pfad zum vollständigen Zertifikat (inkl. Zertifikatskette)
    ssl_certificate /etc/letsencrypt/live/lab47.ifalabs.org/fullchain.pem; # managed by Certbot

    # Pfad zum privaten Schlüssel des Zertifikats
    ssl_certificate_key /etc/letsencrypt/live/lab47.ifalabs.org/privkey.pem; # managed by Certbot

    # Empfohlene SSL-Einstellungen von Let's Encrypt
    # (TLS-Versionen, Cipher Suites, etc.)
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot

    # Diffie-Hellman Parameter für erhöhte Sicherheit
    # beim Schlüsselaustausch (Forward Secrecy)
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}

# --- HTTP Server (Port 80) – Weiterleitung auf HTTPS ---
server {
    # Leitet alle HTTP-Anfragen permanent (301) auf HTTPS um.
    # Stellt sicher, dass die Applikation ausschliesslich
    # verschlüsselt erreichbar ist.
    if ($host = lab47.ifalabs.org) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    # Hört auf unverschlüsselten HTTP-Traffic
    listen 80;
    server_name lab47.ifalabs.org;

    # Alle anderen Anfragen auf Port 80, die nicht die bekannte
    # Domain verwenden, werden mit 404 abgewiesen.
    return 404; # managed by Certbot
}
